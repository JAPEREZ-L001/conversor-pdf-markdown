# OPENROUTER_API_KEY: Required for OpenRouter API calls (PDF to Markdown conversion).
# Get your key at: https://openrouter.ai/keys
# The key starts with sk-or-...
OPENROUTER_API_KEY="sk-or-YOUR_KEY_HERE"

# GEMINI_API_KEY: Required for Google AI Studio API calls (Gemini 2.0 Flash).
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSyYOUR_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
